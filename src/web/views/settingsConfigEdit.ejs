<link rel="stylesheet" href="/static/css/app.css">
<%- include('partials/nav') %>

<h1>Hello, <%= username %>, User Config Edit</h1>
<p>
  <a href="/settings">Back to Settings</a>
</p>
<h2>
  Editing User: <strong><%= (targetUser && targetUser.username) || targetUserId %></strong>
</h2>

<h3>Current Avatar</h3>
<div class="settings-current-avatar-box">
  <% const currentTypes = ['speaking', 'avatar', 'muted', 'deafened']; %>
  <% const hasCurrentAvatar = currentAvatar && currentTypes.some((type) => !!currentAvatar[type]); %>
  <% if (hasCurrentAvatar) { %>
    <table>
      <thead>
        <tr>
          <th>Speaking</th>
          <th>Avatar</th>
          <th>Muted</th>
          <th>Deafened</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <% currentTypes.forEach((type) => { %>
            <td>
              <% if (currentAvatar[type]) { %>
                <img
                  src="<%= currentAvatar[type] %>"
                  alt="<%= `current-${type}` %>"
                  width="96"
                  height="96"
                  class="avatar-thumb avatar-thumb-96"
                />
              <% } else { %>
                -
              <% } %>
            </td>
          <% }) %>
        </tr>
      </tbody>
    </table>
  <% } else { %>
    <p class="settings-zero-margin">No avatar available.</p>
  <% } %>
</div>

<h3>Available Avatar Sets</h3>
<table>
  <thead>
    <tr>
      <th>Set</th>
      <th>Speaking</th>
      <th>Avatar</th>
      <th>Muted</th>
      <th>Deafened</th>
      <th>Action</th>
    </tr>
  </thead>
  <tbody>
    <tr>
      <td>Default</td>
      <% const defaultTypes = ['speaking', 'avatar', 'muted', 'deafened']; %>
      <% defaultTypes.forEach((type) => { %>
        <td>
          <% if (defaultAvatarSet && defaultAvatarSet[type]) { %>
            <img
              src="<%= defaultAvatarSet[type] %>"
              alt="<%= `default-${type}` %>"
              width="64"
              height="64"
              class="avatar-thumb avatar-thumb-64"
            />
          <% } else { %>
            -
          <% } %>
        </td>
      <% }) %>
      <td>
        <form method="post" action="/settings/<%= targetUserId %>/avatar-select">
          <input type="hidden" name="assetId" value="default" />
          <button type="submit">Choose</button>
        </form>
      </td>
    </tr>

    <% if (userAllAvatars && userAllAvatars.length) { %>
      <% userAllAvatars.forEach((asset) => { %>
        <% const itemByType = Object.fromEntries((asset.items || []).map((item) => [item.assetType, item])); %>
        <tr>
          <td><%= asset.assetId %></td>
          <% defaultTypes.forEach((type) => { %>
            <% const item = itemByType[type]; %>
            <td>
              <% if (item) { %>
                <img
                  src="<%= `/uploads/${ownerUserId}/${asset.assetId}/${item.fileName}` %>"
                  alt="<%= `${asset.assetId}-${type}` %>"
                  width="64"
                  height="64"
                  class="avatar-thumb avatar-thumb-64"
                />
              <% } else { %>
                -
              <% } %>
            </td>
          <% }) %>
          <td>
            <form method="post" action="/settings/<%= targetUserId %>/avatar-select">
              <input type="hidden" name="assetId" value="<%= asset.assetId %>" />
              <button type="submit">Choose</button>
            </form>
          </td>
        </tr>
      <% }) %>
    <% } %>
  </tbody>
</table>
