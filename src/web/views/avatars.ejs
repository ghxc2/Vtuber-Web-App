<h1>Hello, <%= username %>, Welcome to /avatars</h1>
<h2>Create Avatar Set</h2>

<form
  method="post"
  action="/avatars/<%= ownerUserId %>/PLACEHOLDER"
  enctype="multipart/form-data"
  onsubmit="this.action = `/avatars/<%= ownerUserId %>/${encodeURIComponent(this.assetId.value)}`;"
>
  <label for="assetId">Set Name</label>
  <input
    id="assetId"
    name="assetId"
    type="text"
    placeholder="e.g. avatar1"
    required
  />
  <button type="submit">Upload</button>
</form>
<h2>Uploaded Avatars</h2>
<% if (avatars && avatars.length) { %>
  <table>
    <thead>
      <tr>
        <th>Set</th>
        <th>Avatar</th>
        <th>Speaking</th>
        <th>Muted</th>
        <th>Deafened</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% avatars.forEach((asset) => { %>
        <% const itemByType = Object.fromEntries((asset.items || []).map((item) => [item.assetType, item])); %>
        <% const types = ['avatar', 'speaking', 'muted', 'deafened']; %>
        <tr>
          <td><%= asset.assetId %></td>
          <% types.forEach((type) => { %>
            <% const item = itemByType[type]; %>
            <td>
              <% if (item) { %>
                <img
                  src="<%= `/uploads/${ownerUserId}/${asset.assetId}/${item.fileName}` %>"
                  alt="<%= `${asset.assetId}-${type}` %>"
                  width="64"
                  height="64"
                  style="object-fit: cover; border-radius: 6px;"
                />
              <% } else { %>
                -
              <% } %>
            </td>
          <% }) %>
          <td>
            <form method="get" action="/avatars/<%= ownerUserId %>/<%= asset.assetId %>/edit" style="display:inline;">
              <button type="submit">Edit</button>
            </form>
            <form
              method="post"
              action="/avatars/<%= ownerUserId %>/<%= asset.assetId %>/delete"
              style="display:inline;"
              onsubmit="return confirm('Delete this avatar set and all its images?');"
            >
              <button type="submit">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } else { %>
  <p>No uploaded avatars found.</p>
<% } %>
