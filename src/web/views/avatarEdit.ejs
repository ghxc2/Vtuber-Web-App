<link rel="stylesheet" href="/static/css/app.css">
<%- include('partials/nav') %>

<h1>Hello, <%= username %>, Edit Avatar Set</h1>
<p>
  <a href="/avatars">Back to Avatars</a>
</p>

<h2>
  Asset ID: <strong><%= assetId %></strong>
</h2>

<% const itemByType = assetsByType || {}; %>
<% const types = ['speaking', 'avatar', 'muted', 'deafened']; %>

<h2>Edit Files</h2>

  <table>
    <thead>
      <tr>
        <th></th>
        <% types.forEach((type) => { %>
          <th><%= type %></th>
        <% }) %>
      </tr>
    </thead>
    <tbody>
      <tr>
        <th>Preview</th>
        <% types.forEach((type) => { %>
          <% const item = itemByType[type]; %>
          <td>
            <% if (item) { %>
              <img
                src="<%= `/uploads/${ownerUserId}/${assetId}/${item.fileName}` %>"
                alt="<%= `${assetId}-${type}` %>"
                width="128"
                height="128"
                class="avatar-thumb avatar-thumb-128 avatar-thumb-contain"
              />
            <% } else { %>
              -
            <% } %>
          </td>
        <% }) %>
      </tr>
      <tr>
        <th>File</th>
        <% types.forEach((type) => { %>
          <% const item = itemByType[type]; %>
          <td><%= item ? item.fileName : '-' %></td>
        <% }) %>
      </tr>
      <tr>
        <th>Replace</th>
        <% types.forEach((type) => { %>
          <td>
            <form
              method="post"
              action="/avatars/<%= ownerUserId %>/<%= assetId %>/<%= type %>"
              enctype="multipart/form-data"
              class="inline-form js-avatar-upload-form"
              data-upload-action-prefix="/avatars/<%= ownerUserId %>/<%= assetId %>"
            >
              <input
                id="<%= type %>File"
                name="avatars"
                type="file"
                accept="image/png,image/jpeg,image/gif"
                class="js-auto-submit-upload"
                data-asset-type="<%= type %>"
              />
            </form>
          </td>
        <% }) %>
      </tr>
      <tr>
        <th>Delete</th>
        <% types.forEach((type) => { %>
          <% const item = itemByType[type]; %>
          <td>
            <form
              method="post"
              action="/avatars/<%= ownerUserId %>/<%= assetId %>/<%= type %>/delete"
              class="inline-form js-confirm-delete-avatar-type"
            >
              <button type="submit" <%= item ? '' : 'disabled' %>>
                Delete
              </button>
            </form>
          </td>
        <% }) %>
      </tr>
    </tbody>
  </table>
<script src="/static/js/avatarEditPage.js"></script>
